# --- Main section

[ $# -eq 0 ] && help_message_opt

ARGC=$#
while [ $# -gt 0 ]; do
	case $1 in
		-h | --help)
			help_message_opt
			exit
			;;
		-l | --list)
			help_message_cmd
			exit
			;;
		-- )
			;;
		*)
			echo_error_msg "Unknown option [$1]"
			help_message_opt
			exit
			;;
		-c | --command)
			shift
			[ $# -eq 0 ] && help_message_cmd
			while [ $# -gt 0 ]; do
				case $1 in
					print-label )
						print_label
						shift
						;;
					-- )
						echo "reached end of options"
						break
						;;
					*)
						echo_error_msg "Unknown command [$1]"
						help_message_cmd
						exit
						;;
				esac
			done
			;;
	esac
done
